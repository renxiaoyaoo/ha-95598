# 必填：95598 登录账号和密码
ACCOUNT="xxx"
PASSWORD="xxxx"

# 可选：同一批户号绑定了多个 95598 登录名时，可以配置登录凭据池。
# 配置后程序会优先使用 LOGIN_CREDENTIALS，并在登录失败/验证码无法通过时按顺序轮换。
# 注意：这里应该只放“登录后能看到同一批户号”的账号，否则数据会混在同一个实例里。
# LOGIN_CREDENTIALS='[{"account":"account1","password":"password1","label":"main"},{"account":"account2","password":"password2","label":"backup"}]'

# 可选：忽略指定用电户号，多个户号用英文逗号分隔。
# 适合一个账号绑定多户，但其中某些户不想同步到 Home Assistant 的情况。
# IGNORE_USER_ID=

## Home Assistant / MQTT 发布
# 如果要接入 Home Assistant，这里必须填一个可访问的 MQTT Broker。
# Home Assistant 通过 MQTT Discovery 自动发现实体，不需要手写 configuration.yaml。
# 如果暂时没有 MQTT Broker，可以把 MQTT_HOST 留空，程序仍会抓取并写入 SQLite，但不会发布 HA 实体。
# Docker 里访问宿主机上的 Mosquitto，通常使用 host.docker.internal。
# 如果 MQTT 在别的容器、NAS 或服务器上，请改成对应主机名或 IP。
MQTT_HOST="host.docker.internal"
MQTT_PORT=1883

# MQTT Broker 开启用户名密码认证时填写；没有认证就保持注释。
# MQTT_USERNAME=""
# MQTT_PASSWORD=""

## 同步频率和运行节奏
# 每天第一轮同步的大致开始时间，格式 HH:MM。
JOB_START_TIME="07:00"

# 每天同步次数。程序会围绕 JOB_START_TIME 自动错开多次运行，避免固定时间高频访问。
JOB_TIMES=2

# 同步失败后的重试次数。
RETRY_TIMES_LIMIT=3

# 页面操作后的基础等待秒数。网络慢或页面加载不稳定时可以调大。
RETRY_WAIT_TIME_OFFSET_UNIT=5

# 定期把缓存状态重新发布到 MQTT。MQTT retain 已能覆盖大多数重启场景，通常无需高频发布；设为 0 可关闭。
REPUBLISH_INTERVAL_MINUTES=60

# 每次同步最近多少天的日用电数据，支持 7 或 30
DAILY_USAGE_WINDOW_DAYS=7

# 是否额外发布谷/平/峰/尖细项传感器。默认关闭，实体更少；开启后 Home Assistant 会多出分时细项实体。
PUBLISH_TOU_DETAIL_SENSORS=false

## 电价配置
# 默认使用 config/tou_price_config.json。仓库默认只是湖南居民阶梯电价示例。
# 如果你要使用自己的本地配置，建议复制一份到 config/tou_price_config.local.json，并设置：
# TOU_PRICE_CONFIG=config/tou_price_config.local.json

## 排障快照
# 页面截图、错误快照和验证码调试图片保留天数，过期会自动清理。
TRACE_RETENTION_DAYS=7

# 调试时才打开。会保存更重的 HTML、browser log 和 performance log，占用更多磁盘。
# DEBUG_PAGE_TRACE_DETAIL=false

## 登录兜底
# 点选验证码最多自动刷新次数；低置信或点错后会换图继续尝试。
# captcha_solver 会自动保存成功/失败样本，并基于历史失败提高保守阈值。
CAPTCHA_POINT_CLICK_MAX_REFRESHES=4
# 是否每天自动离线回放本地验证码样本。默认关闭，适合开发者在自己的环境里迭代 solver。
CAPTCHA_AUTO_REPLAY=false

# 密码登录触发 RK001 后的冷却小时数。冷却期内跳过密码登录，直接进入二维码，减少反复触发风控。
PASSWORD_LOGIN_ERROR_COOLDOWN_HOURS=24

# 密码登录失败或验证码无法自动通过时，是否切换到二维码登录。
# qrcode：保存二维码到 data/login_qr_code.png，并可通过 Telegram 推送。
# none：不使用二维码兜底。
LOGIN_FALLBACK=qrcode

# 单张二维码最多等待次数和每次等待秒数；站点二维码通常约 60 秒失效。
QR_CODE_LOGIN_WAIT_COUNT=6
QR_CODE_LOGIN_WAIT_TIME_INTERVAL_UNIT=10
# 二维码过期或等待超时时，最多自动刷新并重新推送几次。
QR_CODE_LOGIN_REFRESH_LIMIT=1

## 通知
# none：不发送通知。
# telegram：发送登录二维码和数据停更告警。
NOTIFIER=none

# NOTIFIER=telegram 时填写。
# TG_BOT_TOKEN=""
# TG_CHAT_ID=""
# Telegram API 代理域名。默认直连官方 API；如果 api.telegram.org 无法访问，可以改成你的反代地址。
# 例如：https://tg-api.example.com
# TG_API_BASE_URL="https://api.telegram.org"

# 最新日数据落后超过多少天后发送停更告警。只在启用通知器时生效。
STALE_DATA_ALERT_DAYS=2

## 调试专用
# 默认只截取普通视口截图。打开后会尝试保存整页截图，更慢、更占资源。
# DEBUG_FULL_PAGE_SCREENSHOT=true
